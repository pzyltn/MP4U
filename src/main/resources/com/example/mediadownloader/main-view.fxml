<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.mediadownloader.MainController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="appTitle" text="MP4U Media Downloader" />
   <TextField id="urlField" fx:id="urlField" promptText="YouTube URL" />
   <VBox alignment="CENTER" spacing="5.0">
      <children>
         <Label text="Save as (optional):" />
         <TextField fx:id="fileNameField" promptText="Leave blank for default title" />
      </children>
   </VBox>
   <HBox alignment="CENTER" spacing="5.0">
      <children>
         <TextField fx:id="downloadFolderField" editable="false" promptText="Set download location..." />
         <Button mnemonicParsing="false" onAction="#onBrowseClick" text="Browse" />
      </children>
   </HBox>
   <HBox alignment="CENTER" spacing="5.0">
      <children>
         <Text strokeType="OUTSIDE" strokeWidth="0.0" text="File format:" />
         <ComboBox fx:id="formatComboBox" />
      </children>
   </HBox>
   <HBox alignment="CENTER" spacing="5.0">
      <children>
         <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Video quality:" />
         <ComboBox fx:id="videoQualityComboBox" />
      </children>
   </HBox>
   <HBox alignment="CENTER" layoutX="30.0" layoutY="396.0" spacing="5.0">
      <children>
         <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Audio quality:" />
         <ComboBox fx:id="audioQualityComboBox" />
      </children>
   </HBox>
   <HBox alignment="CENTER" layoutX="30.0" layoutY="319.0" spacing="5.0">
      <children>
         <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Captions:" />
         <HBox fx:id="captionsContainer" />
      </children>
   </HBox>
    <Button id="downloadButton" fx:id="downloadButton" accessibleText="Download Button" onAction="#onDownloadClick" text="Download" />
   <ProgressBar fx:id="progressBar" prefWidth="200.0" progress="0.0" />
   <Label fx:id="statusLabel" text="Progress" />
</VBox>
